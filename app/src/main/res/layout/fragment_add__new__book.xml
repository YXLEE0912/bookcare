<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Add_New_Book">


<!-- TODO: Your UI widgets go here -->
    <ImageView
        android:id="@+id/IVLogo"
        android:layout_width="37dp"
        android:layout_height="39dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/bookcare_logo" />

    <TextView
        android:id="@+id/TVAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="9dp"
        android:text="BookCare"
        app:layout_constraintBottom_toBottomOf="@+id/IVLogo"
        app:layout_constraintStart_toEndOf="@+id/IVLogo"
        app:layout_constraintTop_toTopOf="@+id/IVLogo" />

    <View
        android:id="@+id/view2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="7dp"
        android:background="#181616"
        app:layout_constraintTop_toBottomOf="@+id/IVLogo" />

    <TextView
        android:id="@+id/TVBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:layout_marginTop="21dp"
        android:text="Back"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view2" />

    <TextView
        android:id="@+id/TVListABook"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="11dp"
        android:text="List a Book"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/TVBack" />

    <TextView
        android:id="@+id/TVTitleDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:text="Share your books with the community"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@+id/TVListABook"
        app:layout_constraintTop_toBottomOf="@+id/TVListABook" />

    <TextView
        android:id="@+id/TVBookTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Book Title"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/TVTitleDescription"
        app:layout_constraintTop_toBottomOf="@+id/TVTitleDescription" />

    <EditText
        android:id="@+id/ETBookTitle"
        android:layout_width="0dp"
        android:layout_height="17dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="28dp"
        android:background="#FFE0B2"
        android:ems="10"
        android:hint="Enter Book Title"
        android:inputType="text"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/TVBookTitle"
        app:layout_constraintTop_toBottomOf="@+id/TVBookTitle" />

    <TextView
        android:id="@+id/TVAuthor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Author"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/ETBookTitle"
        app:layout_constraintTop_toBottomOf="@+id/ETBookTitle" />

    <EditText
        android:id="@+id/ETAuthor"
        android:layout_width="0dp"
        android:layout_height="17dp"
        android:layout_marginTop="2dp"
        android:background="#FFE0B2"
        android:ems="10"
        android:hint="Enter Author Name"
        android:inputType="text"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@+id/ETBookTitle"
        app:layout_constraintStart_toStartOf="@+id/TVAuthor"
        app:layout_constraintTop_toBottomOf="@+id/TVAuthor" />

    <TextView
        android:id="@+id/TVGenre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Genre"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/ETAuthor"
        app:layout_constraintTop_toBottomOf="@+id/ETAuthor" />

    <Spinner
        android:id="@+id/SPGenre"
        android:layout_width="0dp"
        android:layout_height="17dp"
        android:layout_marginTop="5dp"
        android:backgroundTint="#FFE0B2"
        android:entries="@array/book_genre"
        app:layout_constraintEnd_toEndOf="@+id/ETAuthor"
        app:layout_constraintStart_toStartOf="@+id/TVGenre"
        app:layout_constraintTop_toBottomOf="@+id/TVGenre" />

    <TextView
        android:id="@+id/TVCondition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:text="Condition"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/SPGenre"
        app:layout_constraintTop_toBottomOf="@+id/SPGenre" />

    <Spinner
        android:id="@+id/SPCondition"
        android:layout_width="0dp"
        android:layout_height="17dp"
        android:layout_marginTop="5dp"
        android:backgroundTint="#FFE0B2"
        android:entries="@array/condition_type"
        app:layout_constraintEnd_toEndOf="@+id/SPGenre"
        app:layout_constraintStart_toStartOf="@+id/TVCondition"
        app:layout_constraintTop_toBottomOf="@+id/TVCondition" />

    <TextView
        android:id="@+id/TVListingType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Listing Type"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/SPCondition"
        app:layout_constraintTop_toBottomOf="@+id/SPCondition" />

    <RadioGroup
        android:id="@+id/rgAction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="@+id/SPCondition"
        app:layout_constraintStart_toStartOf="@+id/TVListingType"
        app:layout_constraintTop_toBottomOf="@+id/TVListingType">

        <RadioButton
            android:id="@+id/rbDonate"
            android:layout_width="match_parent"
            android:layout_height="21dp"
            android:text="Donate" />

        <RadioButton
            android:id="@+id/rbExchange"
            android:layout_width="match_parent"
            android:layout_height="23dp"
            android:layout_marginTop="8dp"
            android:text="Exchange" />
    </RadioGroup>

    <TextView
        android:id="@+id/TVDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Description"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/rgAction"
        app:layout_constraintTop_toBottomOf="@+id/rgAction" />

    <EditText
        android:id="@+id/ETDescription"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginTop="2dp"
        android:background="@null"
        android:ems="10"
        android:gravity="start|top"
        android:hint="Describe the book's content and condition"
        android:inputType="textMultiLine"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="@+id/rgAction"
        app:layout_constraintStart_toStartOf="@+id/TVDescription"
        app:layout_constraintTop_toBottomOf="@+id/TVDescription" />

    <Button
        android:id="@+id/BtnCancel"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="88dp"
        android:layout_marginBottom="24dp"
        android:text="Cancel"
        android:textColor="#000000"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="#888888" />

    <Button
        android:id="@+id/BtnListBook"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="76dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#333533"
        android:text="List Book"
        android:textColor="#FFFFFF"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
