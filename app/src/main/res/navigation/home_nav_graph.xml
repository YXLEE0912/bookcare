<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_nav_graph"
    app:startDestination="@id/navigation_home">

    <!-- Home Page (User Profile Summary) -->
    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.secondhandbooks.fragments.UserProfileFragment"
        android:label="Home"
        tools:layout="@layout/fragment_user_profile">

        <!-- START: THIS IS THE FIX - ADDED THE MISSING ACTION -->
        <!-- Action from Home to the Profile VIEW Page -->
        <action
            android:id="@+id/action_navigation_home_to_profileViewFragment"
            app:destination="@id/profileViewFragment" />
        <!-- END: THIS IS THE FIX -->

        <!-- Action from Home to Eco-Points Page -->
        <action
            android:id="@+id/action_navigation_home_to_ecoPointsFragment"
            app:destination="@id/ecoPointsFragment" />
    </fragment>

    <!-- Explore Page -->
    <fragment
        android:id="@+id/navigation_explore"
        android:name="com.example.secondhandbooks.fragments.ExploreFragment"
        android:label="Explore"
        tools:layout="@layout/fragment_explore" />

    <!-- Community Page -->
    <fragment
        android:id="@+id/navigation_community"
        android:name="com.example.secondhandbooks.fragments.CommunityFragment"
        android:label="Community"
        tools:layout="@layout/fragment_community" />

    <!-- Settings Page -->
    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.example.secondhandbooks.fragments.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <!-- Action from Settings to the VIEW-ONLY profile page -->
        <action
            android:id="@+id/action_navigation_settings_to_profileViewFragment"
            app:destination="@id/profileViewFragment" />
        <!-- Action from Settings to the EDITABLE profile page -->
        <action
            android:id="@+id/action_navigation_settings_to_profileEditFragment"
            app:destination="@id/profileEditFragment" />
    </fragment>

    <!-- Destination: Eco-Points Page -->
    <fragment
        android:id="@+id/ecoPointsFragment"
        android:name="com.example.secondhandbooks.fragments.EcoPointsFragment"
        android:label="Eco-Points"
        tools:layout="@layout/fragment_eco_points" />

    <!-- Destination: VIEW-ONLY Profile Page -->
    <fragment
        android:id="@+id/profileViewFragment"
        android:name="com.example.secondhandbooks.fragments.ProfileViewFragment"
        android:label="View Profile"
        tools:layout="@layout/fragment_profile_view" />

    <!-- Destination: EDITABLE Profile Page -->
    <fragment
        android:id="@+id/profileEditFragment"
        android:name="com.example.secondhandbooks.fragments.ProfileEditFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_profile_edit" />

</navigation>





